// LGVI Platform V2 — Schéma Prisma
// Corrections V1.1 appliquées :
//   - dateNaissance au lieu du champ age figé
//   - Table WebhookEvent pour FedaPay/KikaPay
//   - Table JournalActions pour la traçabilité
//   - Données médicales stockées en String (chiffrées AES-256 côté app)
//   - UUID pour tous les IDs
//   - editionId présent sur toutes les tables opérationnelles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTHENTIFICATION (Better Auth) ──────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          RoleType  @default(LECTURE_SEULE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  accounts       Account[]
  journalActions JournalAction[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ─── ÉDITIONS ────────────────────────────────────────────────────────────────

model Edition {
  id               String        @id @default(uuid())
  nom              String
  annee            Int
  dateOuverture    DateTime
  dateFermeture    DateTime
  dateDebut        DateTime
  dateFin          DateTime
  capaciteMaximale Int
  statut           EditionStatut @default(PREPARATION)
  description      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  participants         Participant[]
  activites            Activite[]
  groupes              Groupe[]
  paiements            Paiement[]
  presences            Presence[]
  presencesEquipe      PresenceEquipe[]
  participantActivites ParticipantActivite[]
  depenses             Depense[]
  budgetPrevisionnel   BudgetPrevisionnel?
  mediaAlbums          MediaAlbum[]
  emailCampagnes       EmailCampagne[]

  @@map("editions")
}

// ─── PARENTS ─────────────────────────────────────────────────────────────────

model Parent {
  id                  String   @id @default(uuid())
  nom                 String
  prenom              String
  telephonePrincipal  String
  telephoneSecondaire String?
  email               String?
  adresse             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  participants Participant[]
  paiements    Paiement[]

  @@map("parents")
}

// ─── PARTICIPANTS ─────────────────────────────────────────────────────────────

model Participant {
  id            String            @id @default(uuid())
  nom           String
  prenom        String
  sexe          Sexe
  dateNaissance DateTime
  photo         String?
  ecole         String?
  classe        String?
  statut        ParticipantStatut @default(ACTIF)
  editionId     String
  parentId      String

  // Données médicales — chiffrées AES-256 côté application (lib/crypto.ts)
  allergies                String?
  traitements              String?
  restrictionsAlimentaires String?
  observations             String?
  contactUrgence           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edition   Edition               @relation(fields: [editionId], references: [id])
  parent    Parent                @relation(fields: [parentId], references: [id])
  activites ParticipantActivite[]
  groupes   ParticipantGroupe[]
  presences Presence[]
  paiements Paiement[]

  @@map("participants")
}

// ─── ACTIVITÉS ───────────────────────────────────────────────────────────────

model Activite {
  id          String       @id @default(uuid())
  nom         String
  description String?
  type        ActiviteType @default(PRINCIPALE)
  capacite    Int
  salle       String?
  horaires    String?
  editionId   String
  formateurId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  edition      Edition               @relation(fields: [editionId], references: [id])
  formateur    Formateur?            @relation(fields: [formateurId], references: [id])
  participants ParticipantActivite[]

  @@map("activites")
}

model ParticipantActivite {
  id            String   @id @default(uuid())
  participantId String
  activiteId    String
  editionId     String
  estPrincipale Boolean  @default(true)
  createdAt     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  activite    Activite    @relation(fields: [activiteId], references: [id])
  edition     Edition     @relation(fields: [editionId], references: [id])

  @@unique([participantId, activiteId, editionId])
  @@map("participant_activites")
}

// ─── GROUPES ─────────────────────────────────────────────────────────────────

model Groupe {
  id          String   @id @default(uuid())
  nom         String
  capacite    Int
  editionId   String
  formateurId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  edition      Edition            @relation(fields: [editionId], references: [id])
  formateur    Formateur?         @relation(fields: [formateurId], references: [id])
  participants ParticipantGroupe[]
  presences    Presence[]

  @@map("groupes")
}

model ParticipantGroupe {
  id            String   @id @default(uuid())
  participantId String
  groupeId      String
  createdAt     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  groupe      Groupe      @relation(fields: [groupeId], references: [id])

  @@unique([participantId, groupeId])
  @@map("participant_groupes")
}

// ─── FORMATEURS & ÉQUIPE ─────────────────────────────────────────────────────

model Formateur {
  id         String             @id @default(uuid())
  nom        String
  prenom     String
  telephone  String?
  email      String?
  photo      String?
  specialite String?
  categorie  FormateurCategorie @default(FORMATEUR)
  actif      Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  activites       Activite[]
  groupes         Groupe[]
  presencesEquipe PresenceEquipe[]

  @@map("formateurs")
}

// ─── PRÉSENCES ───────────────────────────────────────────────────────────────

model Presence {
  id            String         @id @default(uuid())
  participantId String
  editionId     String
  groupeId      String?
  date          DateTime
  statut        PresenceStatut @default(PRESENT)
  note          String?
  createdAt     DateTime       @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  edition     Edition     @relation(fields: [editionId], references: [id])
  groupe      Groupe?     @relation(fields: [groupeId], references: [id])

  @@unique([participantId, date])
  @@map("presences")
}

model PresenceEquipe {
  id          String         @id @default(uuid())
  formateurId String
  editionId   String
  date        DateTime
  statut      PresenceStatut @default(PRESENT)
  note        String?
  createdAt   DateTime       @default(now())

  formateur Formateur @relation(fields: [formateurId], references: [id], onDelete: Cascade)
  edition   Edition   @relation(fields: [editionId], references: [id])

  @@unique([formateurId, date])
  @@map("presences_equipe")
}

// ─── PAIEMENTS ───────────────────────────────────────────────────────────────

model Paiement {
  id               String           @id @default(uuid())
  participantId    String
  parentId         String
  editionId        String
  inscriptionId    String?
  montant          Float
  montantPaye      Float            @default(0)
  statut           PaiementStatut   @default(en_attente)
  provider         PaiementProvider @default(manuel)
  referenceExterne String?
  datePaiement     DateTime?
  modePaiement     String?
  note             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  participant Participant @relation(fields: [participantId], references: [id])
  parent      Parent      @relation(fields: [parentId], references: [id])
  edition     Edition     @relation(fields: [editionId], references: [id])

  @@map("paiements")
}

// ─── WEBHOOKS (Correction V1.1 — Section 2.4) ────────────────────────────────

model WebhookEvent {
  id         String   @id @default(uuid())
  provider   String
  eventId    String   @unique
  payload    Json
  statut     String
  tentatives Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("webhook_events")
}

// ─── COMPTABILITÉ ─────────────────────────────────────────────────────────────

model Depense {
  id           String           @id @default(uuid())
  editionId    String
  categorie    DepenseCategorie
  description  String
  montant      Float
  date         DateTime
  justificatif String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  edition Edition @relation(fields: [editionId], references: [id])

  @@map("depenses")
}

model BudgetPrevisionnel {
  id                      String   @id @default(uuid())
  editionId               String   @unique
  objectifInscrits        Int
  prixInscription         Float
  objectifSponsorings     Float    @default(0)
  depensesPrevisionnelles Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  edition Edition @relation(fields: [editionId], references: [id])

  @@map("budgets_previsionnels")
}

// ─── COMMUNICATION ────────────────────────────────────────────────────────────

model EmailCampagne {
  id        String      @id @default(uuid())
  editionId String
  sujet     String
  corps     String
  statut    EmailStatut @default(BROUILLON)
  cible     String?
  envoiAt   DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  edition Edition    @relation(fields: [editionId], references: [id])
  logs    EmailLog[]

  @@map("email_campagnes")
}

model EmailLog {
  id           String   @id @default(uuid())
  campagneId   String
  destinataire String
  statut       String
  createdAt    DateTime @default(now())

  campagne EmailCampagne @relation(fields: [campagneId], references: [id])

  @@map("email_logs")
}

// ─── GALERIE MÉDIA ────────────────────────────────────────────────────────────

model MediaAlbum {
  id         String    @id @default(uuid())
  editionId  String
  titre      String
  date       DateTime?
  activite   String?
  couverture String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  edition Edition @relation(fields: [editionId], references: [id])
  medias  Media[]

  @@map("media_albums")
}

model Media {
  id           String    @id @default(uuid())
  albumId      String
  cloudinaryId String
  url          String
  type         MediaType @default(PHOTO)
  alt          String?
  ordre        Int       @default(0)
  createdAt    DateTime  @default(now())

  album MediaAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("medias")
}

// ─── PARTENAIRES ─────────────────────────────────────────────────────────────

model Partenaire {
  id           String           @id @default(uuid())
  nom          String
  logo         String?
  contact      String?
  contribution String?
  statut       PartenaireStatut @default(ACTIF)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("partenaires")
}

// ─── ACTUALITÉS ──────────────────────────────────────────────────────────────

model Actualite {
  id        String    @id @default(uuid())
  titre     String
  slug      String    @unique
  contenu   String
  extrait   String?
  image     String?
  publie    Boolean   @default(false)
  publieLe  DateTime?
  metaTitle String?
  metaDesc  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("actualites")
}

// ─── JOURNAL D'ACTIONS ────────────────────────────────────────────────────────

model JournalAction {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entite    String?
  entiteId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("journal_actions")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum RoleType {
  SUPER_ADMIN
  DIRECTION
  COMPTABILITE
  COMMUNICATION
  ACCUEIL
  FORMATEUR
  COORDINATEUR
  LECTURE_SEULE
}

enum EditionStatut {
  PREPARATION
  INSCRIPTIONS_OUVERTES
  EN_COURS
  TERMINEE
  ARCHIVEE
}

enum ParticipantStatut {
  ACTIF
  SUSPENDU
  ARCHIVE
}

enum Sexe {
  M
  F
}

enum ActiviteType {
  PRINCIPALE
  COMPLEMENTAIRE
}

enum PresenceStatut {
  PRESENT
  ABSENT
  RETARD
  DEPART_ANTICIPE
}

enum PaiementStatut {
  en_attente
  partiel
  paye
  annule
  rembourse
}

enum PaiementProvider {
  fedapay
  kikapay
  especes
  mobile_money
  manuel
}

enum FormateurCategorie {
  DIRECTION
  COORDINATION
  FORMATEUR
  ANIMATEUR
  MEDIA
  BENEVOLE
}

enum DepenseCategorie {
  FONCTIONNEMENT
  COMMUNICATION
  RESTAURATION
  MATERIEL
  LOGISTIQUE
  ACTIVITES
  AUTRE
}

enum EmailStatut {
  BROUILLON
  PROGRAMME
  ENVOYE
  ECHEC
}

enum MediaType {
  PHOTO
  VIDEO
}

enum PartenaireStatut {
  ACTIF
  INACTIF
}
