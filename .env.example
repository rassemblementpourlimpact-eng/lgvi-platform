# ─── BASE DE DONNÉES ──────────────────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/lgvi_platform?sslmode=require"

# ─── APPLICATION ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AUTHENTIFICATION (Better Auth) ──────────────────────────────────────────
BETTER_AUTH_SECRET=""        # openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3000"

# ─── CHIFFREMENT DONNÉES MÉDICALES (AES-256) ─────────────────────────────────
# ATTENTION : Ne jamais committer cette clé dans Git
# Générer avec : openssl rand -hex 32
ENCRYPTION_KEY=""

# ─── PAIEMENTS ────────────────────────────────────────────────────────────────
FEDAPAY_PUBLIC_KEY=""
FEDAPAY_SECRET_KEY=""
FEDAPAY_ENVIRONMENT="sandbox"   # "sandbox" ou "live"

KIKAPAY_PUBLIC_KEY=""
KIKAPAY_SECRET_KEY=""

# ─── EMAILS (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── WHATSAPP ─────────────────────────────────────────────────────────────────
# Format international sans le + — ex : 22901614816020
# Téléphone LGVI : +229 01 61 48 16 20
NEXT_PUBLIC_LGVI_WHATSAPP_NUMBER="22901614816020"

# ─── CRON (Vercel) ───────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
CRON_SECRET=""
